# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://paebvobxukhnyvttkavj.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# App
NEXT_PUBLIC_APP_NAME=Roti Bakar Ngeunah
NEXT_PUBLIC_APP_URL=https://rbn-sales-cashflow.vercel.app
NEXT_PUBLIC_LOGIN_USERNAME=owner

# Finance Portal / Purchase Order integration
FINANCE_PORTAL_API_KEY=isi_api_key_di_env
FINANCE_PORTAL_API_URL=https://purchase-order-system-iota.vercel.app/api/finance-portal/data

# Integrasi Sistem Kasir (point_of_sales PHP API)
# POS_API_URL        = URL dasar RPC PHP API POS
#                      Contoh: https://api.rotibakarngeunah.my.id/api/api.php/rpc
# POS_API_SECRET_KEY = Sama dengan API_SECRET_KEY di .env point_of_sales (header X-API-Key)
# KASIR_INTEGRATION_API_KEY = Nilai dari tabel api_keys (is_active=1), dikirim sebagai p_api_key
# Cara mendapatkan: Admin POS -> Settings -> API Keys -> salin key aktif
POS_API_URL=https://api.rotibakarngeunah.my.id/api/api.php/rpc
POS_API_SECRET_KEY=isi_api_secret_key_pos_di_sini
KASIR_INTEGRATION_API_KEY=isi_api_key_kasir_dari_tabel_api_keys

# Integrasi Sistem Inventori (Import Food Waste)
# INVENTORI_API_URL = URL dasar API inventori (tanpa trailing slash)
#                     Contoh: https://inventori-rbn.vercel.app/api
# INVENTORI_API_KEY = API key dari tabel api_keys inventori dengan scope integration:read
#                     (dikirim sebagai header X-API-Key)
INVENTORI_API_URL=isi_url_api_inventori_di_sini
INVENTORI_API_KEY=isi_api_key_inventori_di_sini

# Auto-Sync (Vercel Cron)
# Gunakan string acak yang panjang sebagai secret, contoh: openssl rand -hex 32
CRON_SECRET=isi_cron_secret_random_di_sini

# Supabase Service Role Key (untuk cron job - JANGAN expose ke client!)
# Ambil dari: Supabase Dashboard -> Settings -> API -> service_role
SUPABASE_SERVICE_ROLE_KEY=isi_service_role_key_di_sini
